-- Хоткеи клавиатуры

UserInputService.InputBegan:Connect(function(input, gameProcessed)
  if gameProcessed then return end
  if input.KeyCode == Enum.KeyCode.F5 then
    SetMasterState(not masterEnabled)
  elseif masterEnabled then
    if input.KeyCode == Enum.KeyCode.F1 then
      espEnabled = not espEnabled
      espBtn.Text = "ESP: " .. (espEnabled and "ON" or "OFF")
      espBtn.BackgroundColor3 = espEnabled and Color3.fromRGB(0, 200, 0) or Color3.fromRGB(200, 50, 50)
      UpdateESP()
    elseif input.KeyCode == Enum.KeyCode.F2 then
      autoBatEnabled = not autoBatEnabled
      batBtn.Text = "BAT: " .. (autoBatEnabled and "ON" or "OFF")
      batBtn.BackgroundColor3 = autoBatEnabled and Color3.fromRGB(0, 200, 0) or Color3.fromRGB(50, 150, 200)
      if autoBatEnabled then EquipBat() end
    elseif input.KeyCode == Enum.KeyCode.F3 then
      autoStealEnabled = not autoStealEnabled
      stealBtn.Text = "STEAL: " .. (autoStealEnabled and "ON" or "OFF")
      stealBtn.BackgroundColor3 = autoStealEnabled and Color3.fromRGB(0, 200, 0) or Color3.fromRGB(200, 150, 50)
    elseif input.KeyCode == Enum.KeyCode.F4 then
      infJumpEnabled = not infJumpEnabled
      jumpBtn.Text = "JUMP: " .. (infJumpEnabled and "ON" or "OFF")
      jumpBtn.BackgroundColor3 = infJumpEnabled and Color3.fromRGB(0, 200, 0) or Color3.fromRGB(50, 200, 100)
      if infJumpEnabled then SetupInfiniteJump() end
    elseif input.KeyCode == Enum.KeyCode.F6 then
      antiRagdollEnabled = not antiRagdollEnabled
      ragdollBtn.Text = "ANTIRAG: " .. (antiRagdollEnabled and "ON" or "OFF")
      ragdollBtn.BackgroundColor3 = antiRagdollEnabled and Color3.fromRGB(0, 200, 0) or Color3.fromRGB(200, 50, 200)
    end
  end
end)

