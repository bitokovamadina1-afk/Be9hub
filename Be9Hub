-- Функции для ESP

local function CreateESP(plr)
  if plr == LocalPlayer then return end
  local char = plr.Character
  if not char then return end
  local head = char:FindFirstChild("Head")
  if not head then return end
  
  local billboard = Instance.new("BillboardGui")
  billboard.Adornee = head
  billboard.Size = UDim2.new(0, 100, 0, 50)
  billboard.StudsOffset = Vector3.new(0, 1.5, 0)
  billboard.AlwaysOnTop = true
  billboard.Parent = head
  
  local label = Instance.new("TextLabel")
  label.Size = UDim2.new(1, 0, 1, 0)
  label.BackgroundTransparency = 1
  label.TextColor3 = Color3.fromRGB(255, 255, 255)
  label.TextStrokeTransparency = 0
  label.Font = Enum.Font.GothamBold
  label.TextScaled = true
  label.Text = plr.Name
  label.Parent = billboard
  
  table.insert(espObjects, billboard)
end

local function UpdateESP()
  for _, obj in pairs(espObjects) do
    if obj and obj.Parent then
      obj:Destroy()
    end
  end
  espObjects = {}
  if not masterEnabled or not espEnabled then return end
  for _, plr in pairs(Players:GetPlayers()) do
    CreateESP(plr)
  end
end

-- Функции для авто-биты

local function FindBat()
  local backpack = LocalPlayer.Backpack
  for _, tool in pairs(backpack:GetChildren()) do
    if tool:IsA("Tool") and (string.find(string.lower(tool.Name), "bat") or string.find(string.lower(tool.Name), "baseball")) then
      return tool
    end
  end
  local char = LocalPlayer.Character
  if char then
    for _, tool in pairs(char:GetChildren()) do
      if tool:IsA("Tool") and (string.find(string.lower(tool.Name), "bat") or string.find(string.lower(tool.Name), "baseball")) then
        return tool
      end
    end
  end
  return nil
end

local function EquipBat()
  if batEquipped then return end
  local tool = FindBat()
  if tool and tool.Parent == LocalPlayer.Backpack then
    local humanoid = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
    if humanoid then
      humanoid:EquipTool(tool)
      batTool = tool
      batEquipped = true
    end
  end
end

local function AutoBatCycle()
  if not masterEnabled or not autoBatEnabled then return end
  if not batEquipped or not batTool or batTool.Parent ~= LocalPlayer.Character then
    batEquipped = false
    EquipBat()
  end
  if batTool and batTool.Parent == LocalPlayer.Character then
    local target = nil
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if root then
      local minDist = 50
      for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
          local dist = (root.Position - plr.Character.HumanoidRootPart.Position).Magnitude
          if dist < minDist then
            minDist = dist
            target = plr
          end
        end
      end
    end
    if target and target.Character then
      local hrp = target.Character:FindFirstChild("HumanoidRootPart")
      if hrp then
        -- Для работы отправляем мышь на цель (примерно)
        Mouse.Hit = CFrame.new(hrp.Position)
        -- Логика удара, если доступно
        if batTool:FindFirstChild("ClickDetector") then
          batTool.ClickDetector:Click()
        else
          -- Можно попробовать использовать событие Tool.Activated
          batTool:Activate()
        end
      end
    end
  end
end

