local function AutoStealCycle()
  if not masterEnabled or not autoStealEnabled then 
    stealProgress = 0
    progressFill.Size = UDim2.new(0,0,1,0)
    progressLabel.Text = "STEAL: 0%"
    isStealing = false
    return 
  end
  
  if isStealing then return end
  
  local target = GetStealTarget()
  if target then
    isStealing = true
    local duration = 3 -- Время "воровства"
    stealProgress = 0
    for i = 1, 30 do
      if not autoStealEnabled or not masterEnabled then break end
      stealProgress = i / 30
      progressFill.Size = UDim2.new(stealProgress, 0, 1, 0)
      progressLabel.Text = string.format("STEAL: %d%%", math.floor(stealProgress * 100))
      task.wait(duration / 30)
    end
    if stealProgress >= 1 then
      -- Попытка взять предмет (если у объекта есть родитель)
      if target and target.Parent then
        local humanoidRootPart = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if humanoidRootPart then
          -- Телепортируемся к объекту
          LocalPlayer.Character.HumanoidRootPart.CFrame = target.CFrame * CFrame.new(0, 3, 0)
          task.wait(0.1)
          -- Удаляем или "забираем" объект (простейшая имитация)
          target:Destroy()
        end
      end
    end
    stealProgress = 0
    progressFill.Size = UDim2.new(0, 0, 1, 0)
    progressLabel.Text = "STEAL: 0%"
    isStealing = false
  else
    stealProgress = 0
    progressFill.Size = UDim2.new(0, 0, 1, 0)
    progressLabel.Text = "STEAL: 0%"
  end
end

-- Бесконечный прыжок
local function SetupInfiniteJump()
  local char = LocalPlayer.Character
  if not char then return end
  local humanoid = char:FindFirstChild("Humanoid")
  if humanoid then
    humanoid:SetStateEnabled(Enum.HumanoidStateType.Jumping, true)
    humanoid.JumpPower = 100
  end
end

UserInputService.JumpRequest:Connect(function()
  if masterEnabled and infJumpEnabled and LocalPlayer.Character then
    local hum = LocalPlayer.Character:FindFirstChild("Humanoid")
    if hum and hum:GetState() ~= Enum.HumanoidStateType.Jumping then
      hum:ChangeState(Enum.HumanoidStateType.Jumping)
    end
  end
end)

-- Анти-Рэгдолл (предотвращение)
local function AntiRagdollLoop()
  if not masterEnabled or not antiRagdollEnabled then return end
  local char = LocalPlayer.Character
  if not char then return end
  local humanoid = char:FindFirstChild("Humanoid")
  if humanoid then
    if humanoid:GetState() == Enum.HumanoidStateType.Ragdoll then
      humanoid:ChangeState(Enum.HumanoidStateType.Standing)
    end
    humanoid:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
    humanoid:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
    humanoid:SetStateEnabled(Enum.HumanoidStateType.GettingUp, true)
  end
end

